    # factory action.  E.g.
    #
    #   subtests {
    #     label: "Sideload mapping table"
    #     action_name: "InstallOtherApp"
    #     args {
    #       fields {
    #         key: "apkPath"
    #         value {
    #           string_value: "/path/to/mapping_table_apk_downloaded_from_factory_drive.apk"
    #         }
    #       }
    #     }
    #   }
    subtests {
      label: "HW descriptor Probe/Provision"
      action_name: "HwDescProbeProvision"
      args {
        fields {
          # Deprecated.
          key: "mappingTableSource"
          value {
            string_value: ""
          }
        }
        fields {
          # Deprecated.
          key: "mappingTablePatchSource"
          value {
            string_value: ""
          }
        }
        fields {
          key: "ecComponentManifestSource"
          value {
            string_value: ""
          }
        }
        fields {
          key: "ishComponentManifestSource"
          value {
            string_value: ""
          }
        }
        fields {
          key: "isSpareBoard"
          value {
            bool_value: false
          }
        }
        # TODO: b/496681682 -  Remove skipHardwareDescriptorValidation flag
        # after the validation feature in `dev_ids` tool is supported in
        # required release branches.
        fields {
          key: "skipHardwareDescriptorValidation"
          value {
            bool_value: false
          }
        }
      }
    }
    subtests {
      label: "HW descriptor Verify"
      action_name: "HwDescVerify"
      args {
        fields {
          # Deprecated.
          key: "mappingTableSource"
          value {
            string_value: ""
          }
        }
        fields {
          # Deprecated.
          key: "mappingTablePatchSource"
          value {
            string_value: ""
          }
        }
        fields {
          key: "ecComponentManifestSource"
          value {
            string_value: ""
          }
        }
        fields {
          key: "ishComponentManifestSource"
          value {
            string_value: ""
          }
        }
        fields {
          key: "skipPvtMpApprovalCheck"
          value {
            bool_value: false
          }
        }
        fields {
          key: "isSpareBoard"
          value {
            bool_value: false
          }
        }
      }
    }
    # UpdateCbi must run after HW descriptor provisioning because the
    # UFSC generator depends on the hardware descriptor.
    subtests {
      label: "Reboot"
      action_name: "Reboot"
    }
    subtests {
      label: "UpdateCbi"
      action_name: "UpdateCbi"
    }
  }
  subtests {
    label: "Update GSC firmware"
    action_name: "UpdateGscFirmware"
    allow_reboot: true
    args {
      fields {
        key: "forceRoMode"
        value {
          bool_value: true
        }
      }
      fields {
        key: "upstartMode"
        value {
          bool_value: false
        }
      }
    }
  }
  subtests {
    label: "Check GSC secdata version"
    action_name: "CheckSecData"
    args {
      fields {
        key: "majorVersion"
        value {
          number_value: 1
        }
      }
      fields {
        key: "minorVersion"
        value {
          number_value: 0
        }
      }
    }
  }
  subtests {
    label: "Update Firmware"
    action_name: "UpdateFirmware"
    args {
      fields {
        key: "bundledFirmwareName"
        value {
          string_value: "firmwareUpdater"
        }
      }
    }
  }
  subtests {
    label: "keyboard test"
    action_name: "Keyboard"
    args {
      fields {
        key: "layoutIndex"
        value {
          number_value: 2
        }
      }
      fields {
        key: "timeoutSecs"
        value {
          number_value: 9999999
        }
      }
    }
  }
  subtests {
    label: "Ti50 APRO Verification (post-DVT)"
    action_name: "Ti50ApRoVerification"
    allow_reboot: true
    args {
      fields {
        key: "enableApSwwp"
        value {
          bool_value: true
        }
      }
    }
  }
  subtests {
    label: "Ti50 APRO Verification (pre-DVT)"
    action_name: "Ti50ApRoVerification"
    allow_reboot: true
    args {
      fields {
        key: "enableApSwwp"
        value {
          bool_value: false
        }
      }
    }
  }
  subtests {
    label: "RunIn"
    action_name: "RunIn"
    args {
      fields {
        key: "numFish"
        value {
          number_value: 30000
        }
      }
    }
  }
  subtests {
    label: "Suspend resume stress test"
    action_name: "SuspendResumeStress"
  }
  subtests {
    label: "FanSpeed Group"
    subtests {
      label: "Fan Speed"
      action_name: "FanSpeed"
      args {
        fields {
          key: "targetRpm"
          value {
            list_value {
              values { number_value: 2500 }
              values { number_value: 3500 }
            }
          }
        }
      }
    }
    subtests {
      label: "Fan Speed (Spin Max Then Half)"
      action_name: "FanSpeed"
      args {
        fields {
          key: "spinMaxThenHalf"
          value {
            bool_value: true
          }
        }
      }
    }
    subtests {
      label: "Fan Speed (Percentage Margin)"
      action_name: "FanSpeed"
      args {
        fields {
          key: "errorMarginUsePercentage"
          value {
            bool_value: true
          }
        }
        fields {
          key: "errorMargin"
          value {
            number_value: 10
          }
        }
      }
    }
    subtests {
      label: "Fan Speed (Percentage Target Speed)"
      action_name: "FanSpeed"
      args {
        fields {
          key: "speedUsePercentage"
          value {
            bool_value: true
          }
        }
        fields {
          key: "targetRpm"
          value {
            list_value {
              values { number_value: 50 }
              values { number_value: 75 }
            }
          }
        }
      }
    }
    subtests {
      label: "Fan Speed (Specific fan)"
      action_name: "FanSpeed"
      args {
        fields {
          key: "fanId"
          value {
            number_value: 0
          }
        }
      }
    }
  }
  subtests {
    label: "Lid Switch Test"
    action_name: "LidSwitch"
    args {
      fields {
        key: "timeoutSecs"
        value {
          number_value: 30
        }
      }
    }
  }
  subtests {
    label: "Download User Image OTA Package"
    action_name: "SyncFactoryServer"
    allow_reboot: true
    args {
      fields {
        key: "downloadOtaPackage"
        value {
          bool_value: true
        }
      }
    }
  }
  subtests {
    label: "Install User Image OTA Package"
    action_name: "OtaUpdate"
  }
  subtests {
    label: "Finalize"
    should_restart_all_subtests: true
    subtests {
      label: "Barrier"
      action_name: "CheckPoint"
      action_on_failure: ACTION_STOP
      args {
        fields {
          key: "checkFromRoot"
          value {
            bool_value: true
          }
        }
      }
    }
    subtests {
      label: "Remove VPD: activate_date"
      action_name: "RemoveVpdKeys"
      action_on_failure: ACTION_STOP
      args {
        fields {
          key: "rwKeysToRemove"
          value {
            list_value {
              values {
                string_value: "activate_date"
              }
            }
          }
        }
      }
    }
    subtests {
      label: "Enable Post ManufacturingApp"
      action_name: "EnablePostManufacturingApp"
      action_on_failure: ACTION_STOP
    }
    subtests {
      label: "Vpd Validation"
      action_name: "VpdValidation"
      action_on_failure: ACTION_STOP
    }
    subtests {
      label: "Clear TPM owner"
      action_name: "ClearTpmOwner"
      action_on_failure: ACTION_STOP
    }
    subtests {
      label: "Verify EK"
      action_name: "VerifyEk"
      action_on_failure: ACTION_STOP
    }
    subtests {
      label: "Production Mode Group"
      subtests {
        label: "Identify SoC"
        action_name: "IdentifySoC"
      }
      subtests {
        label: "MTK Production Mode"
        run_if: {
          label: "Verify MTK SoC Device Data"
          action_name: "VerifyDeviceData"
          args {
            fields {
              key: "expectedKeyAndValue"
              value {
                list_value: {
                  values {
                    string_value: "factory.soc_type"
                  }
                  values {
                    string_value: "MTK"
                  }
                }
              }
            }
          }
        }
        subtests {
          label: "Download Efuse from factory Drive"
          action_name: "DownloadFactoryDrive"
          args {
            fields {
              key: "paths"
              value {
                list_value {
                  values {
                    list_value {
                      values {
                        string_value: "/efuse_dir/efuse_v1.0_jtag_dis"
                      }
                      values {
                        string_value: "/tmp/efuse_v1.0_jtag_dis"
                      }
                    }
                  }
                }
              }
            }
            fields {
              key: "timeoutSecs"
              value {
                number_value: 30
              }
            }
          }
        }
        subtests {
          label: "Program efuse"
          action_name: "ExecShell"
          args {
            fields {
              key: "command"
              value {
                string_value: "/tmp/efuse_v1.0_jtag_dis | grep -q 'efuse blow succ'"
              }
            }
          }
        }
        subtests {
          label: "Reboot"
          action_name: "Reboot"
          action_on_failure: ACTION_STOP
        }
      }
      subtests {
        label: "Intel Production Mode"
        run_if: {
          label: "Verify Intel SoC Device Data"
          action_name: "VerifyDeviceData"
          args {
            fields {
              key: "expectedKeyAndValue"
              value {
                list_value: {
                  values {
                    string_value: "factory.soc_type"
                  }
                  values {
                    string_value: "INTEL"
                  }
                }
              }
            }
          }
        }
        # Download necessary files to `/tmp` directory.
        subtests {
          label: "Download files from factory Drive"
          action_name: "DownloadFactoryDrive"
          args {
            fields {
              key: "paths"
              value {
                list_value {
                  values {
                    list_value {
                      values {
                        string_value: "/MEManuf_dir/MEManuf"
                      }
                      values {
                        string_value: "/tmp/MEManuf"
                      }
                    }
                  }
                  values {
                    list_value {
                      values {
                        string_value: "/xml_dir/project_eol.xml"
                      }
                      values {
                        string_value: "/tmp/project_eol.xml"
                      }
                    }
                  }
                }
              }
            }
            fields {
              key: "timeoutSecs"
              value {
                number_value: 30
              }
            }
          }
        }
        subtests {
          label: "Intel Enable Production Mode"
          action_name: "IntelEnableProductionMode"
        }
      }
      # Make sure the image signing is completed before running this test item,
      # otherwise the device will fail to boot. See b/453566273#comment30 for
      # more details.
      subtests {
        label: "Qualcomm Production Mode"
        run_if: {
          label: "Verify QCOM SoC Device Data"
          action_name: "VerifyDeviceData"
          args {
            fields {
              key: "expectedKeyAndValue"
              value {
                list_value: {
                  values {
                    string_value: "factory.soc_type"
                  }
                  values {
                    string_value: "QCOM"
                  }
                }
              }
            }
          }
        }
        subtests {
          label: "QCOM Enable Production Mode"
          action_name: "ExecShell"
          args {
            fields {
              key: "command"
              value {
                string_value: "qfprom_program_fuses.sh"
              }
            }
          }
        }
      }
    }
    subtests {
      label: "ProvisionGSC"
      action_name: "ProvisionGSC"
      action_on_failure: ACTION_STOP
    }
    subtests {
      label: "Enable Ap Write Protect"
      action_name: "ApWriteProtect"
      action_on_failure: ACTION_STOP
    }
    subtests {
      label: "Enable Ec Write Protect"
      action_name: "EcWriteProtect"
      action_on_failure: ACTION_STOP
    }
    subtests {
      label: "Clear GBB flags"
      action_name: "ExecShell"
      action_on_failure: ACTION_STOP
      args {
        fields {
          key: "command"
          value {
            string_value: "futility gbb --set --flash --flags=0"
          }
        }
      }
    }
    subtests {
      label: "Disable dev mode"
      action_name: "ExecShell"
      action_on_failure: ACTION_STOP
      args {
        fields {
          key: "command"
          value {
            string_value: "crossystem disable_dev_request=1"
          }
        }
      }
    }
    subtests {
      label: "Enable OEM Lock"
      action_name: "ExecShell"
      action_on_failure: ACTION_STOP
      args {
        fields {
          key: "command"
          value {
            string_value: "crossystem oem_lock=1"
          }
        }
      }
    }
    subtests {
      label: "Verify GSC Before Lock"
      action_name: "VerifyGscBeforeLock"
      action_on_failure: ACTION_STOP
    }
    subtests {
      label: "Lock GSC"
      action_name: "LockGSC"
      action_on_failure: ACTION_STOP
    }
    subtests {
      label: "Upload CSR Data"
      action_name: "UploadCsr"
      action_on_failure: ACTION_STOP
    }
    subtests {
      label: "Upload Factory Report"
      action_name: "UploadFactoryReport"
      action_on_failure: ACTION_STOP
    }
    subtests {
      label: "Switch to User Image"
      action_name: "OtaFinalize"
      action_on_failure: ACTION_STOP
    }
  }
}
