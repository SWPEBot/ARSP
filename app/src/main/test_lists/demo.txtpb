      label: "Fan Speed"
      action_name: "FanSpeed"
      args {
        fields {
          key: "targetRpm"
          value {
            list_value {
              values { number_value: 2500 }
              values { number_value: 3500 }
            }
          }
        }
      }
    }
    subtests {
      label: "Fan Speed (Spin Max Then Half)"
      action_name: "FanSpeed"
      args {
        fields {
          key: "spinMaxThenHalf"
          value {
            bool_value: true
          }
        }
      }
    }
    subtests {
      label: "Fan Speed (Percentage Margin)"
      action_name: "FanSpeed"
      args {
        fields {
          key: "errorMarginUsePercentage"
          value {
            bool_value: true
          }
        }
        fields {
          key: "errorMargin"
          value {
            number_value: 10
          }
        }
      }
    }
    subtests {
      label: "Fan Speed (Percentage Target Speed)"
      action_name: "FanSpeed"
      args {
        fields {
          key: "speedUsePercentage"
          value {
            bool_value: true
          }
        }
        fields {
          key: "targetRpm"
          value {
            list_value {
              values { number_value: 50 }
              values { number_value: 75 }
            }
          }
        }
      }
    }
    subtests {
      label: "Fan Speed (Specific fan)"
      action_name: "FanSpeed"
      args {
        fields {
          key: "fanId"
          value {
            number_value: 0
          }
        }
      }
    }
  }
  subtests {
    label: "Lid Switch Test"
    action_name: "LidSwitch"
    args {
      fields {
        key: "timeoutSecs"
        value {
          number_value: 30
        }
      }
    }
  }
  subtests {
    label: "Download User Image OTA Package"
    action_name: "SyncFactoryServer"
    allow_reboot: true
    args {
      fields {
        key: "downloadOtaPackage"
        value {
          bool_value: true
        }
      }
    }
  }
  subtests {
    label: "Install User Image OTA Package"
    action_name: "OtaUpdate"
  }
  subtests {
    label: "Finalize"
    should_restart_all_subtests: true
    subtests {
      label: "Barrier"
      action_name: "CheckPoint"
      action_on_failure: ACTION_STOP
      args {
        fields {
          key: "checkFromRoot"
          value {
            bool_value: true
          }
        }
      }
    }
    subtests {
      label: "Enable Post ManufacturingApp"
      action_name: "EnablePostManufacturingApp"
      action_on_failure: ACTION_STOP
    }
    subtests {
      label: "Vpd Validation"
      action_name: "VpdValidation"
      action_on_failure: ACTION_STOP
    }
    subtests {
      label: "Clear TPM owner"
      action_name: "ClearTpmOwner"
      action_on_failure: ACTION_STOP
    }
    subtests {
      label: "Verify EK"
      action_name: "VerifyEk"
      action_on_failure: ACTION_STOP
    }
    subtests {
      label: "Production Mode Group"
      subtests {
        label: "Identify SoC"
        action_name: "IdentifySoC"
      }
      subtests {
        label: "MTK Production Mode"
        run_if: {
          label: "Verify MTK SoC Device Data"
          action_name: "VerifyDeviceData"
          args {
            fields {
              key: "expectedKeyAndValue"
              value {
                list_value: {
                  values {
                    string_value: "factory.soc_type"
                  }
                  values {
                    string_value: "MTK"
                  }
                }
              }
            }
          }
        }
        subtests {
          label: "Download Efuse from factory Drive"
          action_name: "DownloadFactoryDrive"
          args {
            fields {
              key: "paths"
              value {
                list_value {
                  values {
                    list_value {
                      values {
                        string_value: "/efuse_dir/efuse_v1.0_jtag_dis"
                      }
                      values {
                        string_value: "/tmp/efuse_v1.0_jtag_dis"
                      }
                    }
                  }
                }
              }
            }
            fields {
              key: "timeoutSecs"
              value {
                number_value: 30
              }
            }
          }
        }
        subtests {
          label: "Program efuse"
          action_name: "ExecShell"
          args {
            fields {
              key: "command"
              value {
                string_value: "/tmp/efuse_v1.0_jtag_dis | grep -q 'efuse blow succ'"
              }
            }
          }
        }
        subtests {
          label: "Reboot"
          action_name: "Reboot"
          action_on_failure: ACTION_STOP
        }
      }
      subtests {
        label: "Intel Production Mode"
        run_if: {
          label: "Verify Intel SoC Device Data"
          action_name: "VerifyDeviceData"
          args {
            fields {
              key: "expectedKeyAndValue"
              value {
                list_value: {
                  values {
                    string_value: "factory.soc_type"
                  }
                  values {
                    string_value: "INTEL"
                  }
                }
              }
            }
          }
        }
        subtests {
          label: "Intel Enable Production Mode"
          action_name: "IntelEnableProductionMode"
        }
      }
    }
    subtests {
      label: "ProvisionGSC"
      action_name: "ProvisionGSC"
      action_on_failure: ACTION_STOP
    }
    subtests {
      label: "Enable Ap Write Protect"
      action_name: "ApWriteProtect"
      action_on_failure: ACTION_STOP
    }
    subtests {
      label: "Enable Ec Write Protect"
      action_name: "EcWriteProtect"
      action_on_failure: ACTION_STOP
    }
    subtests {
      label: "Clear GBB flags"
      action_name: "ExecShell"
      action_on_failure: ACTION_STOP
      args {
        fields {
          key: "command"
          value {
            string_value: "futility gbb --set --flash --flags=0"
          }
        }
      }
    }
    subtests {
      label: "Disable dev mode"
      action_name: "ExecShell"
      action_on_failure: ACTION_STOP
      args {
        fields {
          key: "command"
          value {
            string_value: "crossystem disable_dev_request=1"
          }
        }
      }
    }
    subtests {
      label: "Disable GSC factory mode"
      action_name: "DisableGSCFactoryMode"
      action_on_failure: ACTION_STOP
    }
    subtests {
      label: "Upload Factory Report"
      action_name: "SyncFactoryServer"
      action_on_failure: ACTION_STOP
      args {
        fields {
          key: "uploadReport"
          value {
            bool_value: true
          }
        }
      }
    }
    subtests {
      label: "Switch to User Image"
      action_name: "OtaFinalize"
      action_on_failure: ACTION_STOP
    }
  }
}
